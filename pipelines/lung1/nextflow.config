// Nextflow config for the qradiomics.nf template.
//
// Profiles let you swap the qr execution environment without changing
// the workflow:
//
//   nextflow run qradiomics.nf -profile local       # qr on PATH
//   nextflow run qradiomics.nf -profile docker      # qradiomics container
//   nextflow run qradiomics.nf -profile slurm       # HPC scheduler

profiles {

    local {
        process.executor = 'local'
        // assumes qradiomics[rtstruct] is installed in the current env
    }

    docker {
        process.executor = 'local'
        process.container = 'ghcr.io/choilab-jefferson/qradiomics:0.9.0'
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
        process.cpus = 4
        process.memory = '16 GB'
        process.time = '2h'
    }
}

// Cache process work directories so re-runs only execute new/failed tasks.
resume = true

// Be polite to the filesystem: keep one process per patient.
process {
    errorStrategy = 'finish'      // finish in-flight tasks before aborting on first failure
    maxRetries    = 1
    cache         = 'lenient'
}

// Useful timeline + report
timeline { enabled = true; file = "${params.outdir}/timeline.html" }
report   { enabled = true; file = "${params.outdir}/report.html"   }
dag      { enabled = true; file = "${params.outdir}/dag.html"      }
trace    { enabled = true; file = "${params.outdir}/trace.txt"     }
