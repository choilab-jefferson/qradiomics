{
  "version": "0.9",
  "name": "tcia_to_ml_survival",
  "description": "TCIA download \u2192 DICOM \u2192 outcome-prediction ML model (5 stages).",
  "vars": {
    "cohort_root": "runs/lung1/dicom",
    "clinical_csv": "lung1/clinical/clinical.csv",
    "outdir": "runs/lung1",
    "nrrd_dir": "runs/lung1/nrrd",
    "roi": "GTV-1",
    "pattern": "nsclc-survival",
    "task": "survival",
    "outcome": "OS_event",
    "time_col": "OS_days",
    "event_col": "OS_event",
    "collection": "NSCLC-Radiomics",
    "modalities": "CT,RTSTRUCT",
    "max_series": 0
  },
  "steps": [
    {
      "id": "tcia_series",
      "cmd": "tcia series",
      "stage": "data",
      "args": {
        "collection": "{collection}",
        "output": "{outdir}/series.csv"
      },
      "inputs": [],
      "outputs": [
        "{outdir}/series.csv"
      ],
      "per_patient": false
    },
    {
      "id": "tcia_download",
      "cmd": "tcia download",
      "stage": "data",
      "args": {
        "manifest": "{outdir}/series.csv",
        "output": "{outdir}/dicom",
        "max-series": "{max_series}"
      },
      "inputs": [
        "{outdir}/series.csv"
      ],
      "outputs": [
        "{outdir}/dicom"
      ],
      "per_patient": false
    },
    {
      "id": "manifest_dicom",
      "cmd": "convert manifest-from-dir",
      "stage": "data",
      "args": {
        "dataset-root": "{cohort_root}",
        "image-glob": "**/CT",
        "mask-glob": "**/RS.*.dcm",
        "output": "{outdir}/dicom_manifest.csv"
      },
      "inputs": [],
      "outputs": [
        "{outdir}/dicom_manifest.csv"
      ],
      "per_patient": false
    },
    {
      "id": "convert_ct",
      "cmd": "convert dicom-series",
      "stage": "image",
      "args": {
        "input": "{cohort_root}/{patient_id}/CT",
        "output": "{nrrd_dir}/{patient_id}_CT.nrrd"
      },
      "inputs": [],
      "outputs": [
        "{nrrd_dir}/{patient_id}_CT.nrrd"
      ],
      "per_patient": true
    },
    {
      "id": "convert_rt",
      "cmd": "convert rtstruct",
      "stage": "image",
      "args": {
        "dicom-dir": "{cohort_root}/{patient_id}/CT",
        "rtstruct": "{cohort_root}/{patient_id}/RTSeries/RS.dcm",
        "roi": "{roi}",
        "output": "{nrrd_dir}/{patient_id}_{roi}-label.nrrd"
      },
      "inputs": [
        "{nrrd_dir}/{patient_id}_CT.nrrd"
      ],
      "outputs": [
        "{nrrd_dir}/{patient_id}_{roi}-label.nrrd"
      ],
      "per_patient": true
    },
    {
      "id": "manifest_nrrd",
      "cmd": "convert manifest-from-dir",
      "stage": "data",
      "args": {
        "dataset-root": "{nrrd_dir}",
        "image-glob": "*_CT.nrrd",
        "mask-glob": "*_{roi}-label.nrrd",
        "output": "{outdir}/manifest.csv"
      },
      "inputs": [
        "{nrrd_dir}"
      ],
      "outputs": [
        "{outdir}/manifest.csv"
      ],
      "per_patient": false
    },
    {
      "id": "extract",
      "cmd": "extract",
      "stage": "features",
      "args": {
        "manifest": "{outdir}/manifest.csv",
        "pattern": "{pattern}",
        "output": "{outdir}/features.csv"
      },
      "inputs": [
        "{outdir}/manifest.csv"
      ],
      "outputs": [
        "{outdir}/features.csv"
      ],
      "per_patient": true
    },
    {
      "id": "merge",
      "cmd": "results merge",
      "stage": "features",
      "args": {
        "features": "{outdir}/features.csv",
        "clinical": "{clinical_csv}",
        "clinical-id-col": "patient_id",
        "time-col": "{time_col}",
        "event-col": "{event_col}",
        "output": "{outdir}/analysis_ready.csv"
      },
      "inputs": [
        "{outdir}/features.csv",
        "{clinical_csv}"
      ],
      "outputs": [
        "{outdir}/analysis_ready.csv"
      ],
      "per_patient": false
    },
    {
      "id": "train",
      "cmd": "ml train",
      "stage": "modeling",
      "args": {
        "input": "{outdir}/analysis_ready.csv",
        "task": "{task}",
        "outcome": "{outcome}",
        "model": "{outdir}/model.pkl",
        "metrics": "{outdir}/cv_metrics.json"
      },
      "inputs": [
        "{outdir}/analysis_ready.csv"
      ],
      "outputs": [
        "{outdir}/model.pkl",
        "{outdir}/cv_metrics.json"
      ],
      "per_patient": false
    },
    {
      "id": "evaluate",
      "cmd": "ml evaluate",
      "stage": "modeling",
      "args": {
        "input": "{outdir}/analysis_ready.csv",
        "model": "{outdir}/model.pkl",
        "task": "{task}",
        "outcome": "{outcome}",
        "report": "{outdir}/evaluation.json"
      },
      "inputs": [
        "{outdir}/analysis_ready.csv",
        "{outdir}/model.pkl"
      ],
      "outputs": [
        "{outdir}/evaluation.json"
      ],
      "per_patient": false
    }
  ]
}