{
  "version": "0.9",
  "name": "tcia_to_ml_survival",
  "description": "TCIA \u2192 outcome-prediction ML model (8 steps, 4 canonical stages).",
  "vars": {
    "outdir": "runs/lung1",
    "nrrd_dir": "runs/lung1/nrrd",
    "clinical_csv": "pipelines/lung1/clinical/clinical.csv",
    "collection": "NSCLC-Radiomics",
    "modalities": "CT,RTSTRUCT",
    "max_series": 0,
    "roi": "GTV-1",
    "pattern": "nsclc-survival",
    "task": "survival",
    "outcome": "OS_event",
    "time_col": "OS_days",
    "event_col": "OS_event"
  },
  "steps": [
    {
      "id": "tcia_series",
      "cmd": "tcia series",
      "stage": "data",
      "args": {
        "collection": "{collection}",
        "output": "{outdir}/series.csv"
      },
      "inputs": [],
      "outputs": [
        "{outdir}/series.csv"
      ],
      "per_patient": false
    },
    {
      "id": "tcia_download",
      "cmd": "tcia download",
      "stage": "data",
      "args": {
        "manifest": "{outdir}/series.csv",
        "output": "{outdir}/dicom",
        "max-series": "{max_series}"
      },
      "inputs": [
        "{outdir}/series.csv"
      ],
      "outputs": [
        "{outdir}/dicom"
      ],
      "per_patient": false
    },
    {
      "id": "tcia_manifest",
      "cmd": "tcia manifest",
      "stage": "data",
      "args": {
        "series": "{outdir}/series.csv",
        "dicom-root": "{outdir}/dicom",
        "output": "{outdir}/dicom_manifest.csv"
      },
      "inputs": [
        "{outdir}/series.csv",
        "{outdir}/dicom"
      ],
      "outputs": [
        "{outdir}/dicom_manifest.csv"
      ],
      "per_patient": false
    },
    {
      "id": "convert_from_manifest",
      "cmd": "convert from-manifest",
      "stage": "image",
      "args": {
        "manifest": "{outdir}/dicom_manifest.csv",
        "nrrd-dir": "{nrrd_dir}",
        "roi": "{roi}",
        "output": "{outdir}/manifest.csv"
      },
      "inputs": [
        "{outdir}/dicom_manifest.csv"
      ],
      "outputs": [
        "{outdir}/manifest.csv"
      ],
      "per_patient": false
    },
    {
      "id": "extract",
      "cmd": "extract",
      "stage": "features",
      "args": {
        "manifest": "{outdir}/manifest.csv",
        "pattern": "{pattern}",
        "output": "{outdir}/features.csv"
      },
      "inputs": [
        "{outdir}/manifest.csv"
      ],
      "outputs": [
        "{outdir}/features.csv"
      ],
      "per_patient": false
    },
    {
      "id": "merge",
      "cmd": "results merge",
      "stage": "features",
      "args": {
        "features": "{outdir}/features.csv",
        "clinical": "{clinical_csv}",
        "clinical-id-col": "patient_id",
        "time-col": "{time_col}",
        "event-col": "{event_col}",
        "output": "{outdir}/analysis_ready.csv"
      },
      "inputs": [
        "{outdir}/features.csv",
        "{clinical_csv}"
      ],
      "outputs": [
        "{outdir}/analysis_ready.csv"
      ],
      "per_patient": false
    },
    {
      "id": "train",
      "cmd": "ml train",
      "stage": "modeling",
      "args": {
        "input": "{outdir}/analysis_ready.csv",
        "task": "{task}",
        "outcome": "{outcome}",
        "model": "{outdir}/model.pkl",
        "metrics": "{outdir}/cv_metrics.json"
      },
      "inputs": [
        "{outdir}/analysis_ready.csv"
      ],
      "outputs": [
        "{outdir}/model.pkl",
        "{outdir}/cv_metrics.json"
      ],
      "per_patient": false
    },
    {
      "id": "evaluate",
      "cmd": "ml evaluate",
      "stage": "modeling",
      "args": {
        "input": "{outdir}/analysis_ready.csv",
        "model": "{outdir}/model.pkl",
        "task": "{task}",
        "outcome": "{outcome}",
        "report": "{outdir}/evaluation.json"
      },
      "inputs": [
        "{outdir}/analysis_ready.csv",
        "{outdir}/model.pkl"
      ],
      "outputs": [
        "{outdir}/evaluation.json"
      ],
      "per_patient": false
    }
  ]
}