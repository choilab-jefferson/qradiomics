# Per-cohort downloaded clinical CSVs (PHI risk + cohort-specific)
pipelines/*/clinical/clinical.csv

# Anonymised clinical outputs of pipelines/heart_local/extract_clinical.py.
# Even with PHI columns dropped + PatientIDs mapped to AnonPatient_NNNN,
# these still encode patient-level outcomes from internal data and are
# redistributed only with explicit study approval.
pipelines/heart_local/clinical_anon/
# Anonymisation maps (re-identification keys) — never publish.
**/anonymization_map.csv
**/pid_map.csv
